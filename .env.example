# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collabdocs?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# WebSocket URL for the editor (optional in production)
# If empty, the app defaults to ws(s)://<current-host>/ws
NEXT_PUBLIC_WS_URL="ws://localhost:1234"

# Dev-only WebSocket server port (used by npm run server)
WS_PORT=1234
